# ══════════════════════════════════════════════
# School ERP — Production Environment Variables
# Copy this to .env.prod and fill in real values
# NEVER commit .env.prod to version control
# ══════════════════════════════════════════════

# Database
DB_USER=erp_prod_user
DB_PASSWORD=CHANGE_ME_STRONG_PROD_PASSWORD
DB_NAME=school_erp_prod

# JWT (use a long random secret — min 64 chars for production)
JWT_SECRET=CHANGE_ME_PROD_JWT_SECRET_VERY_LONG_AND_RANDOM_STRING
JWT_EXPIRATION=86400000

# Email (use SendGrid / AWS SES / SMTP real provider)
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USER=apikey
MAIL_PASS=CHANGE_ME_SENDGRID_API_KEY

# Docker Registry (your Docker Hub account or private registry)
DOCKER_REGISTRY=your-dockerhub-username
APP_VERSION=1.0.0

# Allowed Origins
ALLOWED_ORIGINS=https://admin.schoolerp.app,https://schoolerp.app
