# ══════════════════════════════════════════════
# School ERP — UAT Environment Variables
# Copy this to .env.uat and fill in real values
# NEVER commit .env.uat to version control
# ══════════════════════════════════════════════

# Database
DB_USER=erp_uat_user
DB_PASSWORD=CHANGE_ME_UAT_DB_PASSWORD
DB_NAME=school_erp_uat

# JWT
JWT_SECRET=CHANGE_ME_UAT_JWT_SECRET_MINIMUM_32_CHARS
JWT_EXPIRATION=86400000

# Email (use Mailtrap or similar for UAT)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=CHANGE_ME_MAILTRAP_USER
MAIL_PASS=CHANGE_ME_MAILTRAP_PASS

# PgAdmin
PGADMIN_EMAIL=uat-admin@school.app
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASS

# Allowed Origins for CORS (UAT URL)
ALLOWED_ORIGINS=http://uat.schoolerp.app,http://localhost:3000
